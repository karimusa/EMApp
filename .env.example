# RRA Month-End Orchestration — application bootstrap only
#
# This file is read by the running Flask app (run.py / setup.ps1).
# It contains ONLY the bootstrap connection used to reach MonthEndOrchestrationDB
# so the app can load orchestration.app_connections.
#
# Runtime SQL connections (PRIMARY, REMOTE_SQL, etc.) are stored in the database
# table orchestration.app_connections — never duplicate them here.
#
# Seed-time connection targets for scripts/seed_database.py live in
# scripts/seed.env.example (copy to scripts/seed.env).

SECRET_KEY=change-this-to-a-secure-random-string
HOST=127.0.0.1
PORT=50006
FLASK_ENV=development

# Data source: auto | mock | sql
# auto = SQL when BOOTSTRAP_SERVER is set, otherwise mock (offline dev)
DATA_SOURCE=auto

# Bootstrap — the only server name that belongs in .env (hosts MonthEndOrchestrationDB)
# Example: BOOTSTRAP_SERVER=SDAZ001MLD21
BOOTSTRAP_DRIVER=ODBC Driver 18 for SQL Server
BOOTSTRAP_SERVER=
BOOTSTRAP_DATABASE=MonthEndOrchestrationDB
BOOTSTRAP_USER=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_TRUST_CERT=yes

# Fernet key for orchestration.app_connections.password_encrypted
CONNECTION_SECRET_KEY=
