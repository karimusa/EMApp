# RRA Month-End Orchestration
#
# Configuration model (enterprise):
#   .env  = bootstrap connection ONLY (server hosting MonthEndOrchestrationDB)
#   orchestration.app_connections = ALL runtime SQL connections (PRIMARY, REMOTE_SQL, ...)
#
# The running Flask app reads BOOTSTRAP_* to reach MonthEndOrchestrationDB, then loads
# active rows from orchestration.app_connections. Do not put runtime server names here.
#
# SEED_* variables below are used only by scripts/seed_database.py (initial DB seeding).
# They are NOT read by the running application.

SECRET_KEY=change-this-to-a-secure-random-string
HOST=127.0.0.1
PORT=50006
FLASK_ENV=development

DATA_SOURCE=auto

# Bootstrap - initial connection to load orchestration.app_connections
# BOOTSTRAP_SERVER must point to the server hosting MonthEndOrchestrationDB
BOOTSTRAP_DRIVER=ODBC Driver 18 for SQL Server
BOOTSTRAP_SERVER=SDAZ001MLD21
BOOTSTRAP_DATABASE=MonthEndOrchestrationDB
BOOTSTRAP_USER=MonthEndApp
BOOTSTRAP_PASSWORD=<your real SQL password>
BOOTSTRAP_TRUST_CERT=yes

# Fernet key for orchestration.app_connections.password_encrypted
CONNECTION_SECRET_KEY=<your real fernet key>

# Seed script (scripts/seed_database.py) - rows for orchestration.app_connections
SEED_PRIMARY_SERVER=
SEED_PRIMARY_DATABASE=
SEED_PRIMARY_USER=
SEED_PRIMARY_PASSWORD=
SEED_REMOTE_SERVER=
SEED_REMOTE_DATABASE=msdb
SEED_REMOTE_USER=
SEED_REMOTE_PASSWORD=
