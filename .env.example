# RRA Month-End Orchestration
#
# .env contains ONLY the bootstrap connection (server hosting MonthEndOrchestrationDB).
# Runtime SQL connections are loaded from orchestration.app_connections after bootstrap.
# SEED_* values are used only by scripts/seed_database.py (not the running application).

SECRET_KEY=change-this-to-a-secure-random-string

HOST=127.0.0.1
PORT=50006
FLASK_ENV=development

DATA_SOURCE=auto

# Bootstrap connection (ONLY connection stored in .env)
BOOTSTRAP_DRIVER=ODBC Driver 18 for SQL Server
BOOTSTRAP_SERVER=SDAZ001MLD21
BOOTSTRAP_DATABASE=MonthEndOrchestrationDB
BOOTSTRAP_USER=MonthEndApp
BOOTSTRAP_PASSWORD=MonthEndApp
BOOTSTRAP_TRUST_CERT=yes

# Leave blank if runtime passwords are stored as plain text.
# Populate only when using password_encrypted.
CONNECTION_SECRET_KEY=

# Seed script settings
SEED_PRIMARY_SERVER=
SEED_PRIMARY_DATABASE=
SEED_PRIMARY_USER=
SEED_PRIMARY_PASSWORD=
SEED_REMOTE_SERVER=
SEED_REMOTE_DATABASE=msdb
SEED_REMOTE_USER=
SEED_REMOTE_PASSWORD=
