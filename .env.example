# RRA Month-End Orchestration
SECRET_KEY=dev-secret-key-change-in-production
HOST=127.0.0.1
PORT=50006
FLASK_ENV=development

# Data source: auto | mock | sql
# auto = SQL when BOOTSTRAP_SERVER is set, otherwise mock
DATA_SOURCE=auto

# Bootstrap connection to MonthEndOrchestrationDB
BOOTSTRAP_DRIVER=ODBC Driver 18 for SQL Server
BOOTSTRAP_SERVER=
BOOTSTRAP_DATABASE=MonthEndOrchestrationDB
BOOTSTRAP_USER=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_TRUST_CERT=yes

# Fernet key for orchestration.app_connections.password_encrypted
CONNECTION_SECRET_KEY=
