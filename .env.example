# Flask environment: development | production | testing
FLASK_ENV=development

# Application
SECRET_KEY=change-this-to-a-secure-random-string
HOST=0.0.0.0
PORT=50006

# Logging
LOG_LEVEL=INFO

# Bootstrap connection — used once at startup to read orchestration.app_connections.
# Do NOT hardcode production credentials in source control.
BOOTSTRAP_DRIVER=ODBC Driver 18 for SQL Server
BOOTSTRAP_SERVER=SPUS001BDBEXT
BOOTSTRAP_DATABASE=MonthEndOrchestrationDB
BOOTSTRAP_USER=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_TRUST_CERT=yes

# Fernet key for decrypting orchestration.app_connections.password_encrypted
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTION_SECRET_KEY=
