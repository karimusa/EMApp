{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "EMApp: Run Development Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "env": {
                "FLASK_ENV": "development",
                "PORT": "50006"
            },
            "justMyCode": true
        },
        {
            "name": "EMApp: Pytest",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
