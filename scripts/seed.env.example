# Optional override for scripts/seed_database.py
#
# SEED_* values can also live in the project-root .env (see .env.example).
# Copy this file to scripts/seed.env only if you prefer to keep seed targets
# separate from application bootstrap settings.
#
# The running Flask app never reads SEED_* — runtime connections come from
# orchestration.app_connections after bootstrap.

SEED_PRIMARY_SERVER=
SEED_PRIMARY_DATABASE=
SEED_PRIMARY_USER=
SEED_PRIMARY_PASSWORD=

SEED_REMOTE_SERVER=
SEED_REMOTE_DATABASE=msdb
SEED_REMOTE_USER=
SEED_REMOTE_PASSWORD=
