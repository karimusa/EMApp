# Seed script only — NOT read by the running Flask application.
#
# Copy to scripts/seed.env and fill in values used by scripts/seed_database.py
# to INSERT rows into orchestration.app_connections.
#
# After seeding, manage operational connections in the database table.
# The running app loads them from orchestration.app_connections at startup.

SEED_PRIMARY_SERVER=
SEED_PRIMARY_DATABASE=
SEED_PRIMARY_USER=
SEED_PRIMARY_PASSWORD=

SEED_REMOTE_SERVER=
SEED_REMOTE_DATABASE=msdb
SEED_REMOTE_USER=
SEED_REMOTE_PASSWORD=
